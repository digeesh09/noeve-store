# Copy to apps/api/.env — local development uses http://localhost

# Database
DATABASE_URL=postgresql://noeve:noeve@localhost:5433/noeve?schema=public

# Redis
REDIS_URL=redis://localhost:6380

# API
NODE_ENV=development
API_PORT=3001
# Local dev
API_URL=http://localhost:3001
# Production example:
# API_URL=https://api.yourdomain.com
FORCE_HTTPS=false

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated; use https in production
CORS_ORIGINS=http://localhost:3000,http://localhost:3002
# Production example:
# CORS_ORIGINS=https://store.yourdomain.com,https://admin.yourdomain.com

# Web apps (public) — local dev
NEXT_PUBLIC_API_URL=http://localhost:3001/v1
# Production example:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/v1

# S3-compatible storage (MinIO local)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=noeve-media
S3_ACCESS_KEY=noeve
S3_SECRET_KEY=noeve-secret
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/noeve-media
