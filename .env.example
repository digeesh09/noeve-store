# Copy to apps/api/.env and adjust per app as needed

# Database
DATABASE_URL=postgresql://noeve:noeve@localhost:5433/noeve?schema=public

# Redis
REDIS_URL=redis://localhost:6380

# API
API_PORT=3001
API_URL=http://localhost:3001
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Web apps (public)
NEXT_PUBLIC_API_URL=http://localhost:3001/v1

# S3-compatible storage (MinIO local)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=noeve-media
S3_ACCESS_KEY=noeve
S3_SECRET_KEY=noeve-secret
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/noeve-media
