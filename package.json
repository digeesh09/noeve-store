{
  "name": "noeve",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@noeve/api",
    "dev:web-store": "turbo run dev --filter=@noeve/web-store",
    "dev:web-admin": "turbo run dev --filter=@noeve/web-admin",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @noeve/api exec prisma generate",
    "db:migrate": "pnpm --filter @noeve/api exec prisma migrate dev",
    "db:push": "pnpm --filter @noeve/api exec prisma db push",
    "db:studio": "pnpm --filter @noeve/api exec prisma studio",
    "db:seed": "pnpm --filter @noeve/api run db:seed",
    "test": "turbo run test"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
